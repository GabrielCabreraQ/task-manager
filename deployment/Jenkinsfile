pipeline {
    agent any

    environment {
        DOCKER_CREDENTIALS = credentials('docker-credentials')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Backend') {
            steps {
                bat 'docker build -t gabrielcq/task-backend:latest -f task-backend/Dockerfile task-backend/'
            }
        }

        stage('Build Frontend') {
            steps {
                bat 'docker build -t gabrielcq/task-frontend:latest -f task-frontend/Dockerfile task-frontend/'
            }
        }

        stage('Login Docker Hub') {
            steps {
                bat "echo %DOCKER_CREDENTIALS_PSW% | docker login -u %DOCKER_CREDENTIALS_USR% --password-stdin"
            }
        }

        stage('Push Images') {
            steps {
                bat 'docker push gabrielcq/task-backend:latest'
                bat 'docker push gabrielcq/task-frontend:latest'
            }
        }

        stage('Deploy') {
            steps {
                bat 'docker compose -f deployment/docker-compose.yml down --remove-orphans || true'
                bat 'docker compose -f deployment/docker-compose.yml up -d --build'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completado'
        }
        failure {
            echo 'Pipeline error'
        }
    }
}